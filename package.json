{
  "name": "ai-diagram",
  "version": "0.1.0",
  "description": "AI Diagram: an independent MCP server and web UI for AI-driven diagram generation, editing and export, built on top of the open-source drawio editor (Apache License 2.0) and Google Gemini.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ai-diagram-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "webui": "node dist/webuiServer.js",
    "dev:webui": "tsx src/webuiServer.ts",
    "build:pages": "tsx scripts/build-pages.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.7",
    "puppeteer": "^23.11.1",
    "serve-handler": "^6.1.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
